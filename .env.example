# Required: Anthropic API key for query understanding (Claude Sonnet 4.5 forced tool-use).
# If unset, the system falls back to regex-only extraction and emits loud [WARN] logs.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
# Forced-tool-use + our cached system prompt measures ~6-7s on Sonnet 4.5.
# Override only if you know your latency profile.
ANTHROPIC_TIMEOUT_S=15

# Optional: AWS creds for S3 image fetch. Not required for the MVP pipeline;
# only needed if you run `scripts/download_s3_images.py` or `app/core/s3.py`.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-2
LISTINGS_S3_BUCKET=crawl-data-951752554117-eu-central-2-an
LISTINGS_S3_REGION=eu-central-2
LISTINGS_S3_PREFIX=prod

# Optional: OpenAI key (reserved for v2 eval or fallback reranking).
OPENAI_API_KEY=
