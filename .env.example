# ─── Robin — runtime secrets & config ──────────────────────────────────────
# Copy to .env and fill with your own values. Never commit .env.

# ── AWS S3 ── resolves listing image URLs via app/core/s3.py
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_DEFAULT_REGION=eu-central-2

LISTINGS_S3_BUCKET=crawl-data-951752554117-eu-central-2-an
LISTINGS_S3_REGION=eu-central-2
LISTINGS_S3_PREFIX=prod

# ── Anthropic ── reserved for future Claude integrations (optional today)
ANTHROPIC_API_KEY=sk-ant-api03-your-key
ANTHROPIC_MODEL=claude-sonnet-4-5

# ── OpenAI ── query understanding (app/participant/hard_fact_extraction.py)
#             + enrichment passes 2, 2b, 1e, 4 (enrichment/scripts/pass*.py)
OPENAI_API_KEY=sk-proj-your-key
OPENAI_EXTRACT_MODEL=gpt-5.4-mini-2026-03-17

# ── Nominatim ── enrichment pass 1b (reverse-geocode postal_code + street)
# OSM policy requires a real reachable contact:
# https://operations.osmfoundation.org/policies/nominatim/
NOMINATIM_CONTACT_EMAIL=you@example.com
NOMINATIM_RATE_SEC=1.0

# ── OpenTransportData.swiss OJP 2.0 ── ranking/runtime/ojp_client.py
# Free tier: 50 req/min, 20k/day. Register at:
# https://api-manager.opentransportdata.swiss/
OJP_API_KEY=your-ojp-key
OJP_RATE_PER_MIN=50

# ─── Optional feature flags ────────────────────────────────────────────────
# Set to "0" to disable an ML channel (graceful degradation, still boots).
#   LISTINGS_VISUAL_ENABLED     — SigLIP-2 Giant text→image ranker
#   LISTINGS_TEXT_EMBED_ENABLED — Arctic-Embed-L v2 dense text ranker
#   LISTINGS_DINOV2_ENABLED     — DINOv2 image→image ranker + /similar endpoint
# LISTINGS_VISUAL_ENABLED=1
# LISTINGS_TEXT_EMBED_ENABLED=1
# LISTINGS_DINOV2_ENABLED=1

# Set to "1" in production to enforce HTTPS-only session cookies.
# LISTINGS_COOKIE_SECURE=0
